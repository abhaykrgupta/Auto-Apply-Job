# Database
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# OpenAI
OPENAI_API_KEY=

ANTHROPIC_API_KEY=
# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Automation
PLAYWRIGHT_HEADLESS=true
APPLY_AUTO_SUBMIT=false
MAX_CONCURRENT_APPLICATIONS=3

# Scraping
SCRAPING_INTERVAL_MINUTES=1440
MAX_JOBS_PER_SCRAPE=100

# Rate Limiting
OPENAI_RATE_LIMIT_RPM=50
SCRAPER_REQUEST_DELAY_MS=2000

# Logging
LOG_LEVEL=info

RESEND_API_KEY=
USER_EMAIL=

# Telegram 
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

#linkdin 
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_MAX_JOBS=20   

#backend base url 
NEXT_PUBLIC_API_URL=http://localhost:8000

# Redis + Workers
REDIS_URL=redis://127.0.0.1:6379
ENABLE_WORKERS=true
