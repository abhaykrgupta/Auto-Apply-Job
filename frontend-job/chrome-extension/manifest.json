{
  "manifest_version": 3,
  "name": "Job Agent Co-Pilot",
  "version": "2.0.0",
  "description": "Auto-fill job applications with AI — Greenhouse, Lever, Workday, LinkedIn, Ashby and 15+ more ATS platforms.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://smartapply.indeed.com/*",
    "https://jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://www.glassdoor.com/*",
    "https://wellfound.com/*",
    "https://www.workatastartup.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://wd3.myworkday.com/*",
    "https://wd5.myworkday.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://*.oraclecloud.com/*",
    "https://*.successfactors.com/*",
    "https://*.sapsf.com/*",
    "https://*.workforcenow.adp.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://app.ashbyhq.com/*",
    "https://careers.smartrecruiters.com/*",
    "https://jobs.smartrecruiters.com/*",
    "https://*.bamboohr.com/*",
    "https://*.jazz.co/*",
    "https://*.recruitee.com/*",
    "https://*.breezy.hr/*",
    "https://*.teamtailor.com/*",
    "https://ats.rippling.com/*",
    "https://*.pinpointhq.com/*",
    "https://*.ziprecruiter.com/*",
    "https://*.dice.com/*",
    "https://*.builtin.com/*",
    "https://app.joinhandshake.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Agent Co-Pilot"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/viewjob*",
        "https://smartapply.indeed.com/*",
        "https://jobs.lever.co/*/*",
        "https://*.lever.co/*/apply",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.greenhouse.io/*/jobs/*",
        "https://www.glassdoor.com/job-listing/*",
        "https://wellfound.com/jobs/*",
        "https://www.workatastartup.com/jobs/*",
        "https://*.myworkdayjobs.com/*/job/*",
        "https://wd3.myworkday.com/*/job/*",
        "https://wd5.myworkday.com/*/job/*",
        "https://*.icims.com/jobs/*",
        "https://*.taleo.net/careersection/*",
        "https://*.successfactors.com/careers/*",
        "https://*.sapsf.com/careers/*",
        "https://jobs.ashbyhq.com/*/*",
        "https://app.ashbyhq.com/*/job/*",
        "https://careers.smartrecruiters.com/*/*",
        "https://jobs.smartrecruiters.com/*",
        "https://*.bamboohr.com/jobs/*",
        "https://*.jazz.co/apply/*",
        "https://*.recruitee.com/o/*",
        "https://*.breezy.hr/p/*",
        "https://*.teamtailor.com/jobs/*",
        "https://ats.rippling.com/jobs/*",
        "https://*.pinpointhq.com/jobs/*",
        "https://*.ziprecruiter.com/jobs/*",
        "https://*.dice.com/jobs/*",
        "https://*.builtin.com/job/*",
        "https://app.joinhandshake.com/jobs/*"
      ],
      "js": [
        "src/detector.js",
        "src/classifier.js",
        "src/filler.js",
        "src/overlay.js",
        "src/adapters/greenhouse.js",
        "src/adapters/lever.js",
        "src/adapters/ashby.js",
        "src/adapters/linkedin.js",
        "src/adapters/workday.js",
        "src/adapters/smartrecruiters.js",
        "src/adapters/generic.js",
        "src/content.js"
      ],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/filler.js", "src/overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
